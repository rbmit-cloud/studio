{
  "entities": {
    "VehicleDetails": {
      "title": "Vehicle Details",
      "description": "Details of a vehicle.",
      "type": "object",
      "properties": {
        "licensePlate": {
          "type": "string",
          "description": "Vehicle license plate number."
        },
        "trailerLicensePlate": {
          "type": "string",
          "description": "Trailer license plate number, if any."
        }
      },
      "required": [
        "licensePlate"
      ]
    },
    "Visit": {
      "title": "Visit",
      "description": "A record of a visitor.",
      "type": "object",
      "properties": {
        "visitorName": {
          "type": "string"
        },
        "companyName": {
          "type": "string",
          "description": "The visitor's company (e.g. their employer or transport company)."
        },
        "clientCompany": {
          "type": "string",
          "description": "For transporters, the company they are visiting on behalf of."
        },
        "purposeOfVisit": {
          "type": "string"
        },
        "entryType": {
          "type": "string",
          "enum": [
            "Transportista",
            "Personal"
          ]
        },
        "entryDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "exitDateTime": {
          "type": "string",
  
          "format": "date-time"
        },
        "vehicleDetails": {
          "$ref": "#/backend/entities/VehicleDetails"
        },
        "hostName": {
          "type": "string"
        },
        "department": {
          "type": "string"
        }
      },
      "required": [
        "visitorName",
        "companyName",
        "purposeOfVisit",
        "entryType",
        "entryDateTime"
      ]
    },
    "Host": {
      "title": "Host",
      "description": "An employee who can be visited.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the host."
        },
        "department": {
          "type": "string",
          "description": "Department the host belongs to."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the host."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the host is an administrator."
        },
        "password": {
          "type": "string",
          "description": "Password for the host, if they are an administrator."
        }
      },
      "required": [
        "name"
      ]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/visits/{visitId}": {
      "schema": {
        "$ref": "#/backend/entities/Visit"
      },
      "description": "Collection of all visitor records."
    },
    "/hosts/{hostId}": {
      "schema": {
        "$ref": "#/backend/entities/Host"
      },
      "description": "Collection of all hosts that can be visited."
    }
  }
}
