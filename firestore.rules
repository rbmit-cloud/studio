rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserAuthenticated() {
      return request.auth != null;
    }

    match /visits/{visitId} {
      // Anyone can create a visit record (for the public-facing kiosk)
      allow create: if true;
      
      // Only authenticated users (staff/admins) can view, update (e.g., checkout), or delete visit records
      allow read, update, delete: if isUserAuthenticated();
    }

    match /hosts/{hostId} {
      // Anyone can read the list of hosts (to populate dropdowns in visitor forms)
      allow read: if true;

      // Only authenticated users can create, update, or delete hosts.
      // For a higher security application, you should also check for an admin role/claim.
      allow write: if isUserAuthenticated();
    }
  }
}
