/**
 * Core Philosophy: This ruleset implements a straightforward, secure access model.
 * A user's capabilities are determined by their authentication status.
 *
 * Key Security Decisions:
 * - Admin Access: Any user authenticated with a provider other than 'anonymous' is
 *   considered an administrator. This is secure as long as user accounts are managed
 *   exclusively through the Firebase Console.
 * - Anonymous Write for Visits: Any signed-in user (including anonymous users for the public kiosk)
 *   can create a new visit record. This is a key requirement for the public-facing forms.
 * - Admin-Only Management: Only administrators can read the full list of visits and manage
 *   the list of hosts.
 * - User Privacy: A user's profile document in the `/users` collection is private and can only
 *   be accessed or modified by the user themselves. Listing users is disabled.
 * - Default Deny: All paths not explicitly matched are denied access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Validates if the requesting user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the current user has an 'admin' role. An admin is any user
     * that is authenticated with a provider other than 'anonymous'.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    /**
     * Ensures a document exists before an update or delete operation.
     * This prevents state-changing requests on non-existent data.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * On user profile creation, validates that the document's internal 'id'
     * field matches the user's auth UID, ensuring data integrity.
     */
    function isCreatingOwnUserDoc(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * On user profile update, ensures the internal 'id' field is immutable.
     */
    function isUpdatingOwnUserDoc() {
      return request.resource.data.id == resource.data.id;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages user profile documents. Enforces strict ownership;
     * only the authenticated user can read or write their own profile data.
     * @path /users/{userId}
     * @allow (create) A new user (auth.uid: 'user_abc') creates their own profile at `/users/user_abc`.
     * @deny (get) A user (auth.uid: 'user_xyz') tries to read the profile at `/users/user_abc`.
     * @deny (list) Any user tries to list all documents in the `/users` collection.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingOwnUserDoc(userId);
      allow update: if isOwner(userId) && isExistingDoc() && isUpdatingOwnUserDoc();
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description Stores all visitor log entries. Access is controlled by roles.
     * Any authenticated user (including anonymous) can create a visit.
     * Only Admins can read, update, and delete any visit log.
     * @path /visits/{visitId}
     * @allow (create) An anonymous user from the kiosk creates a new visit document.
     * @allow (list) An authenticated 'admin' user lists all visit documents.
     * @deny (get) An authenticated user without an 'admin' role tries to read a visit.
     * @principle Implements role-based access control (RBAC) for a shared data collection, with open creation for authenticated users.
     */
    match /visits/{visitId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Manages the list of hosts (employees) who can be visited.
     * Any authenticated user can read the list to select a host.
     * Only admins can create, update, or delete hosts.
     * @path /hosts/{hostId}
     * @allow (list) An anonymous user from the kiosk lists all hosts for the dropdown menu.
     * @deny (create) An anonymous user tries to add a new host.
     * @allow (update) An admin updates a host's department.
     * @principle Secures host management to admins while allowing public read for functionality.
     */
    match /hosts/{hostId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
    }
  }
}
